export default async function handler(req,res){res.setHeader('Access-Control-Allow-Origin',process.env.APP_ORIGIN||'*');res.setHeader('Access-Control-Allow-Headers','Content-Type');if(req.method==='OPTIONS')return res.status(204).end();if(req.method!=='POST')return res.status(405).json({error:'Method not allowed'});if(!process.env.OPENAI_API_KEY)return res.status(503).json({error:'AI not configured'});const{question,history=[],context={}}=req.body||{};if(typeof question!=='string'||!question.trim()||question.length>1500)return res.status(400).json({error:'Invalid question'});const instructions=`You are Zibur, a careful, warm educational assistant for internationally relocating nurses and midwives. Use current web search when rules, fees, timelines or professional standards may have changed. Use supplied profile and journey context without inventing facts. Explain nursing topics with definition, relevant pathophysiology, assessment, red flags, nursing priorities, medicine-safety considerations, patient education and escalation. Never diagnose a real person, prescribe, replace emergency care or imply omniscience. For urgent symptoms tell the user to follow local emergency and escalation procedures. Separate education from patient-specific advice. For immigration, legal, tax or financial questions give general orientation, state uncertainty and link to the responsible official authority. Tailor terminology and regulatory context to the saved destination. Maintain conversational continuity and ask at most one useful follow-up question.`;const input=[...history.slice(-14),{role:'user',content:`Current app context: ${JSON.stringify(context)}\n\nQuestion: ${question}`}];try{const r=await fetch('https://api.openai.com/v1/responses',{method:'POST',headers:{Authorization:`Bearer ${process.env.OPENAI_API_KEY}`,'Content-Type':'application/json'},body:JSON.stringify({model:process.env.OPENAI_MODEL||'gpt-5.6-terra',instructions,input,tools:[{type:'web_search'}],max_output_tokens:900})});const data=await r.json();if(!r.ok)return res.status(502).json({error:'AI provider error'});return res.status(200).json({answer:data.output_text||'Please try asking that another way.'})}catch{return res.status(502).json({error:'AI connection failed'})}}
